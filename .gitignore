# --- Rust (backend) -----------------------------------------------------------
/target

# --- Node / Vite (frontend) ---------------------------------------------------
/frontend/node_modules
/frontend/dist
/frontend/tsconfig.tsbuildinfo
# Vite's pre-bundled deps cache. Regenerated from node_modules + package.json
# on next `vite` run, so safe (and expected) to ignore. `**/` catches both
# `/.vite` and `/frontend/.vite` depending on where vite was invoked from.
**/.vite
# Dependency-manager debug logs that show up after failed installs.
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Project runtime artifacts ------------------------------------------------
# Working stylesheet — auto-generated from themes/pastel.css on first run
# and rewritten as the user edits CSS. Not source.
/styles.css
# User projects (Save Project) — local files, not in-tree.
*.map2art-project.json

# --- Editor / IDE state -------------------------------------------------------
/.claude
/.idea
/.vscode
*.swp
*.swo
*~

# --- OS junk ------------------------------------------------------------------
.DS_Store
Thumbs.db

# --- Env / secrets ------------------------------------------------------------
.env
.env.*
!.env.example
